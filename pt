function Invoke-FileOrganizer {
    param([string]$TargetDirectory = ".")
    Write-Host "`nв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—" -ForegroundColor Cyan
    Write-Host "в•‘                  AUTOMATED FILE ORGANIZER                     в•‘" -ForegroundColor Cyan
    Write-Host "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ" -ForegroundColor Cyan

    $TargetDirectory = (Resolve-Path $TargetDirectory -ErrorAction SilentlyContinue).Path
    if (-not $TargetDirectory) { Write-Host "вқҢ Directory not found." -ForegroundColor Red; return }
    Write-Host "`nрҹ“Қ Organizing: $TargetDirectory" -ForegroundColor Yellow

    $ImagesDir    = "Images"; $DocumentsDir = "Documents"; $VideosDir = "Videos"
    $MusicDir     = "Music";  $ArchivesDir  = "Archives"

    foreach ($folder in @($ImagesDir,$DocumentsDir,$VideosDir,$MusicDir,$ArchivesDir)) {
        New-Item -Path (Join-Path $TargetDirectory $folder) -ItemType Directory -Force -ErrorAction SilentlyContinue | Out-Null
    }

    $movedCount = 0; $skippedCount = 0
    $allItems = Get-ChildItem -Path $TargetDirectory -ErrorAction SilentlyContinue

    foreach ($item in $allItems) {
        if ($item.PSIsContainer) { continue }
        if ($item.Name -eq (Split-Path $PSCommandPath -Leaf)) { $skippedCount++; continue }
        $ext = $item.Extension.TrimStart('.').ToLower()
        if ([string]::IsNullOrWhiteSpace($ext)) { Write-Host "[SKIP]     '$($item.Name)'" -ForegroundColor DarkGray; $skippedCount++; continue }

        $destinationFolder = switch ($ext) {
            { $_ -in @("jpg","jpeg","png","gif","svg","webp") }                          { Write-Host "[IMAGE]    '$($item.Name)'" -ForegroundColor Cyan;    $ImagesDir;    break }
            { $_ -in @("pdf","doc","docx","txt","ppt","pptx","xls","xlsx") }             { Write-Host "[DOCUMENT] '$($item.Name)'" -ForegroundColor Blue;    $DocumentsDir; break }
            { $_ -in @("mp4","mkv","mov","avi") }                                        { Write-Host "[VIDEO]    '$($item.Name)'" -ForegroundColor Magenta; $VideosDir;    break }
            { $_ -in @("mp3","wav","flac") }                                             { Write-Host "[MUSIC]    '$($item.Name)'" -ForegroundColor Green;   $MusicDir;     break }
            { $_ -in @("zip","rar","tar","gz") }                                         { Write-Host "[ARCHIVE]  '$($item.Name)'" -ForegroundColor Yellow;  $ArchivesDir;  break }
            default                                                                      { Write-Host "[SKIP]     '$($item.Name)' вҖ” unknown (.$ext)" -ForegroundColor DarkGray; $skippedCount++; $null }
        }

        if ($destinationFolder) {
            try { Move-Item -Path $item.FullName -Destination (Join-Path $TargetDirectory $destinationFolder) -Force -ErrorAction Stop; $movedCount++ }
            catch { Write-Host "   вқҢ Failed: $_" -ForegroundColor Red; $skippedCount++ }
        }
    }

    Write-Host "`nвң… Done! Moved: $movedCount  Skipped: $skippedCount" -ForegroundColor Green
}

# ================================================================
# SECTION 18: SMART CLEANER вҖ” Cache / Temp / Trash / Duplicates
# ================================================================
#
# Sub-features:
#   A) SCAN   - lists what would be cleaned and total size (safe, no deletion)
#   B) CLEAN  - deletes cache, temp, trash files after confirmation
#   C) DUPES  - finds duplicate files by MD5 hash, lists them
#   D) DEL_DUPES - deletes duplicates keeping one copy per group
#
# Parameters used:
#   -DryRun      вҶ’ scan only, never delete
#   -SkipConfirm вҶ’ skip the interactive "are you sure?" prompt (used by GUI)
#   -Path        вҶ’ directory to scan for duplicates (defaults to $HOME)
# ================================================================

function Get-HumanSize {
    param([long]$Bytes)
    if ($Bytes -ge 1GB) { return "{0:N2} GB" -f ($Bytes / 1GB) }
    if ($Bytes -ge 1MB) { return "{0:N2} MB" -f ($Bytes / 1MB) }
    if ($Bytes -ge 1KB) { return "{0:N2} KB" -f ($Bytes / 1KB) }
    return "$Bytes B"
}

function Invoke-SmartCleaner {
    param(
        [string]$Mode = "SCAN",   # SCAN | CLEAN | DUPES | DEL_DUPES
        [string]$ScanPath = "",
        [switch]$DryRun,
        [switch]$SkipConfirm
    )

    Write-Host "`nв•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—" -ForegroundColor Cyan
    Write-Host "в•‘                   рҹ§Ҫ SMART CLEANER                            в•‘" -ForegroundColor Cyan
    Write-Host "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ" -ForegroundColor Cyan

    # в”Җв”Җ CLEAN MODE (cache / temp / trash) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if ($Mode -eq "SCAN" -or $Mode -eq "CLEAN") {

        # Define target paths to scan/clean
        $targets = @(
            @{ Label="APT Package Cache";  Path="/var/cache/apt/archives";          Pattern="*.deb" }
            @{ Label="APT Lists Cache";    Path="/var/lib/apt/lists";               Pattern="*" }
            @{ Label="Temp Files (/tmp)";  Path="/tmp";                             Pattern="*" }
            @{ Label="User Cache";         Path="$HOME/.cache";                     Pattern="*" }
            @{ Label="Thumbnail Cache";    Path="$HOME/.cache/thumbnails";          Pattern="*" }
            @{ Label="Log Files (old)";    Path="/var/log";                         Pattern="*.gz" }
            @{ Label="Systemd Journals";   Path="/var/log/journal";                 Pattern="*" }
            @{ Label="Trash Files";        Path="$HOME/.local/share/Trash/files";   Pattern="*" }
            @{ Label="Trash Info";         Path="$HOME/.local/share/Trash/info";    Pattern="*.trashinfo" }
        )

        $grandTotal  = [long]0
        $targetSizes = @()

        Write-Host "`nв–¶ SCANNING FOR CLEANABLE FILES..." -ForegroundColor Yellow
        Write-Host ("{0,-30} {1,-12} {2,-8}" -f "TARGET","SIZE","FILES") -ForegroundColor Cyan
        Write-Host ("{0,-30} {1,-12} {2,-8}" -f "в”Җв”Җв”Җв”Җв”Җв”Җ","в”Җв”Җв”Җв”Җ","в”Җв”Җв”Җв”Җв”Җ") -ForegroundColor DarkGray

        foreach ($t in $targets) {
            if (Test-Path $t.Path) {
                $files = Get-ChildItem -Path $t.Path -Filter $t.Pattern -Recurse -File -ErrorAction SilentlyContinue
                $sz    = ($files | Measure-Object -Property Length -Sum).Sum
                if (-not $sz) { $sz = 0 }
                $grandTotal += $sz
                $humanSz = Get-HumanSize -Bytes $sz
                Write-Host ("{0,-30} {1,-12} {2,-8}" -f $t.Label, $humanSz, $files.Count) -ForegroundColor White
                $targetSizes += @{ Label=$t.Label; Path=$t.Path; Pattern=$t.Pattern; Size=$sz; Count=$files.Count }
            } else {
                Write-Host ("{0,-30} {1,-12} {2,-8}" -f $t.Label, "N/A", "вҖ”") -ForegroundColor DarkGray
            }
        }

        Write-Host ""
        Write-Host "   TOTAL RECOVERABLE: $(Get-HumanSize -Bytes $grandTotal)" -ForegroundColor Yellow

        if ($Mode -eq "SCAN" -or $DryRun) {
            Write-Host "`n   в„№пёҸ  Scan complete. Run with Mode=CLEAN to actually delete." -ForegroundColor Cyan
            return
        }

        # в”Җв”Җ Confirmation в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if (-not $SkipConfirm) {
            Write-Host ""
            Write-Host "   вҡ пёҸ  Are you sure you want to delete $(Get-HumanSize -Bytes $grandTotal) of cached/temp/trash files?" -ForegroundColor Red
            Write-Host "   This CANNOT be undone. Type YES to confirm: " -ForegroundColor Yellow -NoNewline
            $answer = Read-Host
            if ($answer -ne "YES") { Write-Host "`n   вқҢ Cancelled. No files were deleted." -ForegroundColor Gray; return }
        }

        # в”Җв”Җ Delete в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        Write-Host ""
        $deletedBytes = [long]0
        $deletedCount = 0

        foreach ($t in $targetSizes) {
            if ($t.Size -eq 0) { continue }
            Write-Host "   рҹ—‘пёҸ  Cleaning: $($t.Label)..." -ForegroundColor Yellow
            try {
                if ($t.Path -like "/var/*") {
                    # Needs sudo for system paths
                    $result = & sudo find $t.Path -maxdepth 3 -type f -name $t.Pattern -delete 2>$null
                } else {
                    $files = Get-ChildItem -Path $t.Path -Filter $t.Pattern -Recurse -File -ErrorAction SilentlyContinue
                    foreach ($f in $files) {
                        try { Remove-Item -Path $f.FullName -Force -ErrorAction Stop; $deletedBytes += $f.Length; $deletedCount++ }
                        catch { }
                    }
                }
                Write-Host "   вң… Done" -ForegroundColor Green
            } catch {
                Write-Host "   вҡ пёҸ  Partial error: $_" -ForegroundColor Yellow
            }
        }

        Write-Host ""
        Write-Host "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor DarkGray
        Write-Host "   вң… CLEAN COMPLETE" -ForegroundColor Green
        Write-Host "   Files deleted : $deletedCount" -ForegroundColor White
        Write-Host "   Space freed   : $(Get-HumanSize -Bytes $deletedBytes)" -ForegroundColor White
        Write-Host "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor DarkGray
        return
    }

    # в”Җв”Җ DUPLICATE FINDER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if ($Mode -eq "DUPES" -or $Mode -eq "DEL_DUPES") {

        $searchDir = if ($ScanPath -and (Test-Path $ScanPath)) { $ScanPath } else { $HOME }
        Write-Host "`nв–¶ SCANNING FOR DUPLICATES IN: $searchDir" -ForegroundColor Yellow
        Write-Host "   (Comparing by MD5 hash вҖ” this may take a moment...)" -ForegroundColor DarkGray

        # Group files by size first (fast pre-filter), then hash
        $hashGroups = @{}
        $allFiles = Get-ChildItem -Path $searchDir -Recurse -File -ErrorAction SilentlyContinue |
            Where-Object { $_.Length -gt 1KB }  # skip tiny files

        $scanned = 0
        foreach ($f in $allFiles) {
            try {
                $hash = (Get-FileHash -Path $f.FullName -Algorithm MD5 -ErrorAction Stop).Hash
                if (-not $hashGroups.ContainsKey($hash)) { $hashGroups[$hash] = @() }
                $hashGroups[$hash] += $f
            } catch { }
            $scanned++
        }

        $dupeGroups = $hashGroups.GetEnumerator() | Where-Object { $_.Value.Count -gt 1 }
        $dupeList   = @($dupeGroups)

        if ($dupeList.Count -eq 0) {
            Write-Host "`n   вң… No duplicate files found in $searchDir" -ForegroundColor Green
            return
        }

        $totalWaste  = [long]0
        $totalDupes  = 0

        Write-Host "`n   Found $($dupeList.Count) duplicate group(s):`n" -ForegroundColor Yellow
        Write-Host ("{0,-60} {1,-12} {2}" -f "FILE","SIZE","HASH") -ForegroundColor Cyan
        Write-Host ("{0,-60} {1,-12} {2}" -f "в”Җв”Җв”Җв”Җ","в”Җв”Җв”Җв”Җ","в”Җв”Җв”Җв”Җ") -ForegroundColor DarkGray

        foreach ($grp in $dupeList) {
            $files = $grp.Value | Sort-Object FullName
            Write-Host "  в”Ңв”Җ DUPLICATE GROUP ($($files.Count) copies) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor Magenta
            $first = $true
            foreach ($f in $files) {
                $sz  = Get-HumanSize -Bytes $f.Length
                $pfx = if ($first) { "  в”Ӯ [KEEP]   " } else { "  в”Ӯ [DUPE]   "; $totalWaste += $f.Length; $totalDupes++ }
                $col = if ($first) { "Green" } else { "Red" }
                $pathDisplay = if ($f.FullName.Length -gt 57) { "..." + $f.FullName.Substring($f.FullName.Length-57) } else { $f.FullName }
                Write-Host ("{0}{1,-57} {2,-12}" -f $pfx, $pathDisplay, $sz) -ForegroundColor $col
                $first = $false
            }
            Write-Host "  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor DarkGray
        }

        Write-Host ""
        Write-Host "   Duplicate files  : $totalDupes" -ForegroundColor White
        Write-Host "   Wasted space     : $(Get-HumanSize -Bytes $totalWaste)" -ForegroundColor Yellow

        if ($Mode -eq "DUPES") {
            Write-Host "`n   в„№пёҸ  Run Mode=DEL_DUPES to remove duplicates (keeps first copy)." -ForegroundColor Cyan
            return
        }

        # в”Җв”Җ Delete duplicates в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        if (-not $SkipConfirm) {
            Write-Host ""
            Write-Host "   вҡ пёҸ  Delete $totalDupes duplicate files, freeing $(Get-HumanSize -Bytes $totalWaste)?" -ForegroundColor Red
            Write-Host "   The FIRST copy of each group will be KEPT. Type YES to confirm: " -ForegroundColor Yellow -NoNewline
            $answer = Read-Host
            if ($answer -ne "YES") { Write-Host "`n   вқҢ Cancelled. No files were deleted." -ForegroundColor Gray; return }
        }

        $delCount = 0; $delBytes = [long]0
        foreach ($grp in $dupeList) {
            $files = $grp.Value | Sort-Object FullName
            $skip  = $true
            foreach ($f in $files) {
                if ($skip) { $skip = $false; continue }
                try {
                    $sz = $f.Length
                    Remove-Item -Path $f.FullName -Force -ErrorAction Stop
                    $delCount++; $delBytes += $sz
                    Write-Host "   рҹ—‘пёҸ  Deleted: $($f.FullName)" -ForegroundColor Red
                } catch { Write-Host "   вҡ пёҸ  Could not delete: $($f.FullName) вҖ” $_" -ForegroundColor Yellow }
            }
        }

        Write-Host ""
        Write-Host "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor DarkGray
        Write-Host "   вң… DUPLICATES REMOVED" -ForegroundColor Green
        Write-Host "   Files deleted : $delCount" -ForegroundColor White
        Write-Host "   Space freed   : $(Get-HumanSize -Bytes $delBytes)" -ForegroundColor White
        Write-Host "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ" -ForegroundColor DarkGray
    }
}

