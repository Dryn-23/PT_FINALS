        $port = $_
        $service = switch ($port) {
            "22"   { "SSH" } "80" { "HTTP" } "443" { "HTTPS" }
            "3306" { "MySQL" } "5432" { "PostgreSQL" } "8080" { "HTTP-Alt" }
            "53"   { "DNS" } "25" { "SMTP" } "21" { "FTP" }
